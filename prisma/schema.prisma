// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Usuario {
  id        Int      @id @default(autoincrement())
  nombre    String
  email     String   @unique
  password  String
  telefono  String?
  tipo      String   @default("cliente") // "cliente" o "salon"
  createdAt DateTime @default(now())

  citas Cita[]

  @@map("usuarios")
}

model Servicio {
  id           Int      @id @default(autoincrement())
  nombre       String
  categoria    String
  descripcion  String?
  duracion     String
  especialista String
  precio       Float
  imagen       String?  @db.Text
  createdAt    DateTime @default(now())

  citas Cita[]

  @@map("servicios")
}

model Cita {
  id           String   @id @default(cuid())
  fecha        String
  hora         String
  estado       String   @default("Pendiente")
  createdAt    DateTime @default(now())

  usuarioId  Int?
  usuario    Usuario?  @relation(fields: [usuarioId], references: [id])

  servicioId Int?
  servicio   Servicio? @relation(fields: [servicioId], references: [id])

  // Datos desnormalizados para facilitar consultas
  servicioNombre    String?
  categoria         String?
  especialista      String?
  precio            Float?
  duracion          String?

  @@map("citas")
}
